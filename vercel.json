{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "api/**/*.{js,ts}": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(?!(?:_next/|assets/|favicon\\.ico|robots\\.txt|sitemap\\.xml))",
      "destination": "/index.html"
    }
  ]
}
